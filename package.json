{
  "name": "civic-pulse",
  "version": "0.1.0",
  "description": "Open-source government accountability tracker. Monitor promises, parliamentary activity, and ministerial performance across any country, fed by a Claude-powered ingestion agent.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/your-org/civic-pulse",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/civic-pulse.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/civic-pulse/issues"
  },
  "keywords": [
    "civic-tech",
    "open-data",
    "government-accountability",
    "promise-tracker",
    "claude-agent",
    "parliament",
    "transparency"
  ],
  "scripts": {
    "dev": "npm run prebuild && vite",
    "build": "npm run prebuild && vite build && node scripts/overlay-country-public.mjs && node scripts/generate-prerender-pages.mjs && node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "prebuild": "npm run build:promise-sources && npm run build:transcript-sources && npm run build:promises-data",
    "build:deputies": "node scripts/build-deputy-analytics.mjs && npm run build:promise-sources && npm run build:transcript-sources",
    "build:transcript-sources": "node scripts/build-transcript-sources.mjs",
    "build:promise-sources": "node scripts/build-promise-sources.mjs",
    "build:promises-data": "node scripts/build-promises-data.mjs",
    "agent": "node agent/src/cli.mjs",
    "agent:run": "node agent/src/cli.mjs run",
    "agent:dry-run": "node agent/src/cli.mjs run --dry-run",
    "agent:promises": "node agent/src/cli.mjs promises",
    "agent:deputies": "node agent/src/cli.mjs deputies",
    "agent:score-verdict": "node agent/src/agents/verdict.mjs score",
    "a11y": "node scripts/check-accessibility-browser.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@axe-core/playwright": "^4.11.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.11.4",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
