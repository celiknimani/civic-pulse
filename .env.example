# Which country dataset to build/serve. Maps to countries/<COUNTRY>/.
# Default 'example' is the English demo. Set to 'kosovo' to see the real
# reference deployment, or to your own country code once you've added one.
COUNTRY=example

# Public site origin (used in sitemap.xml, OG tags, canonical URLs).
SITE_URL=https://example.com

# Agent runtime (only required when running the agent, not for the web app).
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
